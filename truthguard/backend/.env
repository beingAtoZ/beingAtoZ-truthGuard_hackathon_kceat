# ─────────────────────────────────────────────────────────────────────────────
# TruthGuard — Environment Configuration
# Copy this file to .env and fill in your keys.
# Leave keys blank (or as-is) to use heuristic fallbacks — the app still works.
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini — generates human-readable explanations
# Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Google Fact Check Tools API — cross-references claims
# Get yours at: https://developers.google.com/fact-check/tools/api
GOOGLE_FACT_CHECK_API_KEY=

# NewsAPI — real-time news search (100 req/day free)
# Get yours at: https://newsapi.org/register
NEWS_API_KEY=e0cb2cbabcd5449997f00259b8178f64

# GNews API — secondary news fallback (100 req/day free)
# Get yours at: https://gnews.io/
GNEWS_API_KEY=

# Set to "true" to show illustrative placeholder news articles when no
# NEWS_API_KEY / GNEWS_API_KEY is configured. For demo/presentation use only.
DEMO_MODE=false
